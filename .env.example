# ============================================================
# Autopilot Platform — Root Environment Variables
# Fill this in then run: docker compose up
# ============================================================

# ── Required ─────────────────────────────────────────────────

# Your Anthropic API key (from console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-REPLACE_THIS

# Any long random string — used to sign login tokens
# Generate one at: https://randomkeygen.com (use "Fort Knox Passwords")
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_STRING_abc123xyz789

# ── Stripe (optional for local testing) ───────────────────────
# Get these from dashboard.stripe.com → Developers → API keys
# Use TEST keys (start with sk_test_) for local development
STRIPE_SECRET_KEY=sk_test_REPLACE_THIS
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_THIS

# Create products in Stripe dashboard → Products → Add product
# Copy the Price ID (starts with price_) for each plan
STRIPE_PRICE_STARTER=price_REPLACE_THIS
STRIPE_PRICE_PRO=price_REPLACE_THIS
STRIPE_PRICE_AGENCY=price_REPLACE_THIS

# ── Leave these as-is for local development ───────────────────
DB_HOST=postgres
DB_PORT=5432
DB_NAME=autopilot
DB_USER=autopilot
DB_PASSWORD=autopilot123
REDIS_HOST=redis
REDIS_PORT=6379
FRONTEND_URL=http://localhost:5173
NODE_ENV=development
PORT=3001
